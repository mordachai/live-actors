<form class="lva-simple-config standard-form {{#if showBounce}}lva-bounce-on{{/if}}" autocomplete="off">

  <fieldset>
    <legend>Animation Mode</legend>
    <div class="form-group slim">
      <label>Mode <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="<ul><li><strong>None</strong> — off</li><li><strong>Simple</strong> — bounce/wobble</li><li><strong>Lip-Sync</strong> — mouth shapes</li><li><strong>Hybrid</strong> — lip-sync if sprites exist, else bounce</li><li><strong>Both</strong> — lip-sync + bounce</li></ul>"></i></label>
      <div class="form-fields">
        <select name="mode">
          {{#each modeOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Speaking Indicator</legend>
    <div class="form-group slim">
      <label>Style <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="<strong>Ring</strong> — circle around the token<br><strong>Bubble</strong> — speech bubble above it<br>Separate from the Talking Head indicator."></i></label>
      <div class="form-fields">
        <select name="indicatorStyle">
          {{#each indicatorOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset class="lva-bounce-config">
    <legend>Bounce Config</legend>
    <div class="form-group slim">
      <label>Preset <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Pick a bounce feel:<ul><li><strong>Pulse</strong> — gentle grow/shrink, no jump</li><li><strong>Bouncy</strong> — light, happy bounce</li><li><strong>Wobbly</strong> — tilts side to side</li><li><strong>Stretchy</strong> — squashes and stretches tall</li><li><strong>Toon</strong> — cartoony bounce, tilt and stretch</li><li><strong>Toon Wobble</strong> — Toon, snappier and wobblier</li></ul>"></i></label>
      <div class="form-fields">
        <select name="bouncePreset">
          {{#each presetOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  <footer class="sheet-footer flexrow">
    <button type="button" data-action="save">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>

</form>
