<form class="lva-video-config standard-form {{#if showBounce}}lva-bounce-on{{/if}}" autocomplete="off">

  <fieldset>
    <legend>Animation Mode</legend>
    <div class="form-group slim">
      <label>Mode <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="<ul><li><strong>None</strong> — off</li><li><strong>Simple</strong> — bounce/wobble</li><li><strong>Lip-Sync</strong> — mouth shapes</li><li><strong>Hybrid</strong> — lip-sync if sprites exist, else bounce</li><li><strong>Both</strong> — lip-sync + bounce</li></ul>Needs Foundry Audio/Video enabled (not Disabled)."></i></label>
      <div class="form-fields">
        <select name="videoMode">
          {{#each modeOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset class="lva-bounce-config">
    <legend>Bounce Preset</legend>
    <div class="form-group slim">
      <label>Preset <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Pick a bounce feel (tuned smaller for the A/V tile):<ul><li><strong>Pulse</strong> — gentle grow/shrink, no jump</li><li><strong>Bouncy</strong> — light, happy bounce</li><li><strong>Wobbly</strong> — tilts side to side</li><li><strong>Stretchy</strong> — squashes and stretches tall</li><li><strong>Toon</strong> — cartoony bounce, tilt and stretch</li><li><strong>Toon Wobble</strong> — Toon, snappier and wobblier</li></ul>"></i></label>
      <div class="form-fields">
        <select name="videoBouncePreset">
          {{#each presetOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Clean Mode <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Hide Foundry's A/V chrome on the camera tiles. Per-client — each player sets their own view. Needs Foundry Audio/Video enabled."></i></legend>
    <div class="form-group slim">
      <label>Hide player names</label>
      <div class="form-fields">
        <input type="checkbox" name="cleanName" {{#if cleanName}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim">
      <label>Hide Controls <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Hides status icons, control buttons, the volume slider and the per-tile controls bar."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="cleanControls" {{#if cleanControls}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim">
      <label>Hide Borders <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Hides the coloured border, speaking ring and shadow on tiles (normal + minimized)."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="cleanBorder" {{#if cleanBorder}}checked{{/if}}>
      </div>
    </div>
  </fieldset>

  <footer class="sheet-footer flexrow">
    <button type="button" data-action="save">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>

</form>
