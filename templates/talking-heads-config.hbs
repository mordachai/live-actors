<form class="lva-heads-config standard-form {{#if showBounce}}lva-bounce-on{{/if}} {{#if headOutline}}lva-outline-on{{/if}} {{#if useAvatar}}lva-avatar-on{{/if}} {{#if headAvatarOutline}}lva-avatar-outline-on{{/if}}" autocomplete="off">

  <fieldset>
    <legend>Animation Mode</legend>
    <div class="form-group slim">
      <label>Mode <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="<strong>One mode for all heads</strong>, clamped to each head's assets.<ul><li>Heads with viseme images (sheet / 4 imgs) — every mode</li><li>Avatar or token-only heads — bounce only</li></ul>Mixed world? Use <strong>Hybrid</strong> — lip-sync where possible, bounce otherwise."></i></label>
      <div class="form-fields">
        <select name="headMode">
          {{#each modeOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Speaking Indicator</legend>
    <div class="form-group slim">
      <label>Style <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="<strong>Ring</strong> — coloured border glow<br><strong>Bubble</strong> — speech bubble above the portrait<br>Separate from the canvas token indicator."></i></label>
      <div class="form-fields">
        <select name="headIndicatorStyle">
          {{#each indicatorOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Portrait</legend>
    <div class="form-group slim">
      <label>Always Visible <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="On — portraits stay on screen. Off — a portrait shows only while that player talks. Disable heads entirely with Animation Mode = None."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headsAlways" {{#if headsAlways}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim">
      <label>Prefer Avatar Image <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Show the <strong>{token}-avatar</strong> image (full-body) instead of token art. Solo image, so no lip-sync — follows Mode, clamped to None/Simple. No avatar → uses viseme/token art."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headUseAvatar" {{#if useAvatar}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim">
      <label>Portrait Size (px) <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Width for viseme/token heads. Height scales with the image when Keep Aspect Ratio is on."></i></label>
      <div class="form-fields">
        <input type="range" name="headWidth" min="100" max="340" step="4" value="{{headWidth}}">
        <span class="range-value">{{headWidth}}</span>
      </div>
    </div>
    <div class="form-group slim">
      <label>Avatar Size (px) <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Width for avatar heads. Height always keeps the image's aspect ratio."></i></label>
      <div class="form-fields">
        <input type="range" name="headAvatarWidth" min="100" max="600" step="10" value="{{headAvatarWidth}}">
        <span class="range-value">{{headAvatarWidth}}</span>
      </div>
    </div>
    <div class="form-group slim">
      <label>Keep Aspect Ratio <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Keep natural proportions for viseme/token heads (avatars always do). Off — square crop."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headAspectRatio" {{#if headAspectRatio}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim">
      <label>Show Name <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Show the character name below each portrait."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="showHeadName" {{#if showHeadName}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim">
      <label>Name Size <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Name font multiplier. 1.0 = default (auto-scaled with portrait width)."></i></label>
      <div class="form-fields">
        <input type="range" name="headNameSize" min="0.5" max="2.5" step="0.1" value="{{headNameSize}}">
        <span class="range-value">{{headNameSize}}</span>
      </div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Appearance</legend>
    <div class="form-group slim">
      <label>Portrait Mask <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Optional mask for all portraits. White = visible, transparent/black = hidden. One file for every head."></i></label>
      <div class="form-fields">
        <input type="text" name="headMask" value="{{headMask}}" placeholder="Path to mask image (optional)...">
        <button type="button" data-action="browseMask" title="Browse for mask image">
          <i class="fas fa-file-image"></i>
        </button>
        <button type="button" data-action="clearMask" title="Clear mask">
          <i class="fas fa-trash"></i>
        </button>
      </div>
    </div>
  </fieldset>

  <div class="lva-outline-columns">
  <fieldset class="lva-outline-col lva-outline-col--portrait">
    <legend>Portrait / Viseme Outline <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Applies to viseme/token heads. Always active."></i></legend>
    <div class="form-group slim">
      <label>Outline <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Cartoon outline on the silhouette. Needs alpha — a Portrait Mask, or Cutout for transparent-PNG art. Plain rectangular images keep the normal ring."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headOutline" {{#if headOutline}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim lva-outline-only">
      <label>Cutout Portraits <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Use the portrait PNG's own transparency as the shape — no mask needed. Outline and ring follow that alpha."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headCutout" {{#if headCutout}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim lva-outline-only">
      <label>Width (px)</label>
      <div class="form-fields">
        <input type="range" name="headOutlineWidth" min="1" max="10" step="1" value="{{headOutlineWidth}}">
        <span class="range-value">{{headOutlineWidth}}</span>
      </div>
    </div>
    <div class="form-group slim lva-outline-only">
      <label>Player Colour <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="On — each portrait uses that player's colour. Off — the fixed colour below."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headOutlineAuto" {{#if headOutlineAuto}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim lva-outline-only">
      <label>Colour <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Used only when Player Colour is off."></i></label>
      <div class="form-fields">
        <input type="color" name="headOutlineColor" value="{{headOutlineColor}}">
      </div>
    </div>
  </fieldset>

  <fieldset class="lva-outline-col lva-outline-col--avatar">
    <legend>Avatar Outline <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Applies to avatar heads. Dimmed when Prefer Avatar Image is off."></i></legend>
    <div class="form-group slim">
      <label>Outline <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Outline along the avatar PNG's own alpha silhouette. Separate from the portrait outline."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headAvatarOutline" {{#if headAvatarOutline}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim lva-avatar-outline-only">
      <label>Width (px)</label>
      <div class="form-fields">
        <input type="range" name="headAvatarOutlineWidth" min="1" max="10" step="1" value="{{headAvatarOutlineWidth}}">
        <span class="range-value">{{headAvatarOutlineWidth}}</span>
      </div>
    </div>
    <div class="form-group slim lva-avatar-outline-only">
      <label>Player Colour <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="On — each avatar uses that player's colour. Off — the fixed colour below."></i></label>
      <div class="form-fields">
        <input type="checkbox" name="headAvatarOutlineAuto" {{#if headAvatarOutlineAuto}}checked{{/if}}>
      </div>
    </div>
    <div class="form-group slim lva-avatar-outline-only">
      <label>Colour <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Used only when Player Colour is off."></i></label>
      <div class="form-fields">
        <input type="color" name="headAvatarOutlineColor" value="{{headAvatarOutlineColor}}">
      </div>
    </div>
  </fieldset>
  </div>

  <fieldset class="lva-bounce-config">
    <legend>Bounce Config</legend>
    <div class="form-group slim">
      <label>Preset <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Pick a bounce feel:<ul><li><strong>Pulse</strong> — gentle grow/shrink, no jump</li><li><strong>Bouncy</strong> — light, happy bounce</li><li><strong>Wobbly</strong> — tilts side to side</li><li><strong>Stretchy</strong> — squashes and stretches tall</li><li><strong>Toon</strong> — cartoony bounce, tilt and stretch</li><li><strong>Toon Wobble</strong> — Toon, snappier and wobblier</li></ul>"></i></label>
      <div class="form-fields">
        <select name="headBouncePreset">
          {{#each presetOptions}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
    </div>
  </fieldset>

  {{#if players}}
  <fieldset>
    <legend>Mirror (per player) <i class="fa-solid fa-circle-question lva-help" data-tooltip-direction="UP" data-tooltip-class="lva-help-tip" data-tooltip-html="Flip a portrait so characters face inward. Applies to all viewers."></i></legend>
    {{#each players}}
    <div class="form-group slim">
      <label>{{name}}</label>
      <div class="form-fields">
        <input type="hidden" name="mirrorUserId" value="{{userId}}">
        <label class="lva-mirror-label">
          <input type="checkbox" name="mirror-{{userId}}" {{#if mirrored}}checked{{/if}}>
          Flip portrait horizontally
        </label>
      </div>
    </div>
    {{/each}}
  </fieldset>
  {{/if}}

  <footer class="sheet-footer flexrow">
    <button type="button" data-action="save">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>

</form>
